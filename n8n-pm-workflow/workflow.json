    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('读项目配置').item.json.feishu_webhook }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"msg_type\": \"interactive\",\n  \"card\": {\n    \"header\": {\"title\": {\"tag\": \"plain_text\", \"content\": \"✅ 需求已评估，待确认工时\"}, \"template\": \"green\"},\n    \"elements\": [\n      {\"tag\": \"div\", \"text\": {\"tag\": \"lark_md\", \"content\": \"**需求：**{{ $('读项目配置').item.json.title }}\\n**预估工时：**{{ $json.output.total_person_days }} 人天\\n**排期：**{{ $json.output.suggested_sprint }}\"}},\n      {\"tag\": \"div\", \"text\": {\"tag\": \"lark_md\", \"content\": \"**风险：**{{ ($json.output.risks || []).join('、') }}\"}}\n    ]\n  }\n}",
        "options": {}
      },
      "id": "node-feishu-pass",
